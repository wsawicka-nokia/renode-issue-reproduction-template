# This is a sample RESC script.
# Please change this file and test.robot to include all necessary steps to reproduce your issue.
# Make this repository as self contained as possible.
#

$name?="TestMachine"
$repl?=@https://zephyr-dashboard.renode.io/zephyr_sim/076b625f21444c8ee7ada24bafa5fec55d67e6ab/44771a7b17efb5e2ebc5ace0ab959f913e3980f8/nucleo_h533re/hello_world/hello_world.repl
$bin?=@https://zephyr-dashboard.renode.io/zephyr/076b625f21444c8ee7ada24bafa5fec55d67e6ab/nucleo_h533re/hello_world/hello_world.elf

using sysbus
mach create $name
machine LoadPlatformDescription $repl 

showAnalyzer usart2

macro reset
"""
    sysbus LoadELF $bin
"""
runMacro $reset
